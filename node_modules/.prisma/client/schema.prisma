generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id        String   @id @default(cuid())
  title     String   @default("Untitled Script")
  content   Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#ffb612")
  createdAt DateTime @default(now())
}
