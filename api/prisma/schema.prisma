generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id        String   @id @default(cuid())
  title     String   @default("Untitled Script")
  excerpt   String   @default("A new storytelling masterpiece.")
  type      String   @default("Feature")
  progress  Int      @default(0)
  archived  Boolean  @default(false)
  words     Int      @default(0)
  content   Bytes?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  color     String   @default("#ffb612")
  goal      Int      @default(2000)
  createdAt DateTime @default(now())
  projects  Project[]
}
